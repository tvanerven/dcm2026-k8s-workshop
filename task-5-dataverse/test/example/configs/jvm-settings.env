# NOTE:    All env vars are going to be used by Payara via MPCONFIG, which also makes use of the "directory source".
#          Any secret values should be given in reference only, as they will be mounted to /secrets/k8s/... as files.
#          Reference them here via $${k8s.xxx}, where xxx is the secret key (used as filename) we want to read.
#          If you want to change "k8s" to something else, this will require patching the statefulset secret mount!
#

# Injection by FluxCD postBuild
DATAVERSE_FQDN=dv.ct.gdcc.io
DATAVERSE_SITEURL=http://dv.ct.gdcc.io

DATAVERSE_DB_HOST=postgres
DATAVERSE_DB_USER=${k8s.databaseUsername}
DATAVERSE_DB_PASSWORD=${k8s.databasePassword}
DATAVERSE_DB_NAME=${k8s.databaseName}
DATAVERSE_DB_LOG_JDBC_CALLS=false
DATAVERSE_DB_IS_CONNECTION_VALIDATION_REQUIRED=true
DATAVERSE_DB_CONNECTION_VALIDATION_METHOD=custom-validation
DATAVERSE_DB_VALIDATION_CLASSNAME=org.glassfish.api.jdbc.validation.PostgresConnectionValidation
DATAVERSE_DB_VALIDATE_ATMOST_ONCE_PERIOD_IN_SECONDS=3

DATAVERSE_SOLR_HOST=solr
DATAVERSE_SOLR_CORE=dataverse

DATAVERSE_CORS_ORIGIN=${dataverse.siteurl}

DATAVERSE_MAIL_SYSTEM_EMAIL=FluxCD Tester <fluxcd@mailinator.com>
# This service does not exist. We can patch this later with a deployed maildev service
DATAVERSE_MAIL_MTA_HOST=gateway.mail.svc.cluster.local

# For now, let's not configure the OIDC provider via MPCONFIG but use the existing from the database.
#DATAVERSE_AUTH_OIDC_ENABLED=1

DATAVERSE_API_BLOCKED_ENDPOINTS=admin,builtin-users
DATAVERSE_API_BLOCKED_POLICY=unblock-key
DATAVERSE_API_BLOCKED_KEY=${k8s.apiUnblockKey}

DATAVERSE_PID_PROVIDERS=perma1
DATAVERSE_PID_DEFAULT_PROVIDER=perma1
DATAVERSE_PID_PERMA1_TYPE=perma
DATAVERSE_PID_PERMA1_LABEL=Perma1
DATAVERSE_PID_PERMA1_AUTHORITY=DV
DATAVERSE_PID_PERMA1_PERMALINK_SEPARATOR=/

